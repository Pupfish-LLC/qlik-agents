// ============================================================
// NULL-CLEANING VARIABLE FUNCTIONS
// ============================================================
// Reusable SET variable functions for cleaning nulls, creating
// boolean Dual fields, and guarding date arithmetic.
//
// HOW TO USE:
// 1. Include this file early in your reload script:
//    $(Must_Include=lib://Scripts/clean-null-function.qvs);
// 2. Use in LOAD statements:
//    $(vCleanNull(field_name)) AS [Output.Field]
//    $(vCleanDate(date_field)) AS [Output.Date]
//    $(vDualBool(flag_field, Yes Label, No Label)) AS [Output.Flag]
//
// LIMITATION:
// These variable functions CANNOT wrap expressions containing
// commas. Inside $(), commas separate parameters. If the field
// expression contains ApplyMap, PurgeChar, IF, or any function
// with commas, write the null check inline instead.
//
// Example of what BREAKS:
//   $(vCleanNull(PurgeChar(field, '[]')))
//   The engine sees: $1=PurgeChar(field, $2='[]')
//
// Example of the INLINE workaround:
//   // Cannot use vCleanNull (comma in PurgeChar args)
//   IF(IsNull(PurgeChar(field, '[]')) OR Len(Trim(PurgeChar(field, '[]'))) = 0,
//      Null(), Trim(PurgeChar(field, '[]'))) AS [Output.Field]
// ============================================================

// ============================================================
// vCleanNull: Clean string-encoded nulls to actual Qlik NULL
// ============================================================
// Handles: SQL NULL, empty string, and common string representations
// of null from ETL pipelines, JSON ingestion, and data lakes.
//
// String values caught: 'null', 'nan', 'none', 'n/a', '[null]'
// (case-insensitive, with leading/trailing whitespace trimmed)
//
// Usage: $(vCleanNull(field_name)) AS [Output.Field]
// Input: simple field name or literal (NO commas in argument)
// Output: Null() if null-like, otherwise Trim($1)
// ============================================================
SET vCleanNull = IF(IsNull($1) OR Len(Trim($1)) = 0
    OR Match(Lower(Trim($1)), 'null', 'nan', 'none', 'n/a', '[null]'),
    Null(), Trim($1));

// ============================================================
// vCleanDate: Clean null dates and guard against date arithmetic
// ============================================================
// Returns Null() for null-like dates. Returns the date value
// otherwise. Use this BEFORE any date arithmetic to prevent
// the "NULL date = 0 = December 30, 1899" problem.
//
// Usage: $(vCleanDate(date_field)) AS [Output.Date]
//
// DATE FORMAT DEPENDENCY: Date#(Trim($1)) without a format string
// relies on the app's DateFormat setting (SET DateFormat='YYYY-MM-DD';).
// If your source dates use a different format than the app default,
// you cannot use this variable function -- write Date#(field, 'format')
// inline instead (the comma in Date#() breaks variable expansion anyway).
//
// NUMERIC SERIAL DATES: If the source field is already a Qlik date
// serial number (numeric), Date#() is unnecessary -- Qlik already
// treats it as a date. This function is for STRING date fields only.
//
// For date ARITHMETIC (age, duration), wrap the entire calculation:
//   IF(IsNull($(vCleanDate(birth_date))), Null(),
//       Floor((Today() - $(vCleanDate(birth_date))) / 365.25))
//   AS [Person.Age]
// ============================================================
SET vCleanDate = IF(IsNull($1) OR Len(Trim($1)) = 0
    OR Match(Lower(Trim($1)), 'null', 'nan', 'none', 'n/a', '[null]'),
    Null(), Date#(Trim($1)));

// ============================================================
// vDualBool: Convert a field to a boolean Dual value
// ============================================================
// Creates a Dual() field with text display AND numeric value:
//   True match  -> Dual('$2', 1)   e.g., Dual('Active', 1)
//   False       -> Dual('$3', 0)   e.g., Dual('Inactive', 0)
//   NULL        -> Dual('Unknown', -1)  (distinct sort position)
//
// Usage: $(vDualBool(field_name, True Label, False Label))
// Example: $(vDualBool(is_active, Active, Inactive)) AS [Customer.IsActive]
//
// Benefits:
// - Text display in filter panes: "Active", "Inactive", "Unknown"
// - Numeric aggregation: Sum([Customer.IsActive]) = count of active
// - Correct sort order: Active(1) > Inactive(0) > Unknown(-1)
//
// NOTE: This function uses SET (not LET) because it contains
// Dual() and quotes that must be preserved as a template.
//
// DOMAIN-SPECIFIC VALUES: The Match() only catches generic boolean
// strings ('true', 'yes', 'y', '1', 'active', 'enabled'). If your
// domain uses values like 'approved', 'confirmed', 'open', or
// 'complete' as true indicators, write a custom IF instead of
// using this variable function.
// ============================================================
SET vDualBool = IF(IsNull($1) OR Len(Trim($1)) = 0
    OR Match(Lower(Trim($1)), 'null', 'nan', 'none', 'n/a', '[null]'),
    Dual('Unknown', -1),
    IF(Match(Lower(Trim($1)), 'true', 'yes', 'y', '1', 'active', 'enabled') > 0,
        Dual('$2', 1),
        Dual('$3', 0)));

// ============================================================
// vCleanNumeric: Clean null-like values in numeric fields
// ============================================================
// For numeric fields that may contain string-encoded nulls.
// Returns Null() for null-like values, otherwise returns the
// numeric interpretation of the field.
//
// WARNING: Num#() silently converts non-numeric strings to NULL.
// If a field expected to be numeric contains text values like
// "PENDING", "TBD", or "ERROR", this function will mask that
// signal. Prefer using vCleanNumeric only AFTER you have confirmed
// that the field contains only numeric values and null-like strings.
// For fields with unknown content, inspect distinct values first
// before applying this function.
//
// Usage: $(vCleanNumeric(field_name)) AS [Output.Amount]
// ============================================================
SET vCleanNumeric = IF(IsNull($1) OR Len(Trim($1)) = 0
    OR Match(Lower(Trim($1)), 'null', 'nan', 'none', 'n/a', '[null]'),
    Null(), Num#(Trim($1)));
